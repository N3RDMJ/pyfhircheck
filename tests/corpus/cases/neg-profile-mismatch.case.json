  "expectedStatus": "FAIL",
  "expectedIssueCodes": ["profile.type"],
  "resource": {
    "resourceType": "Patient",
    "id": "pat-wrong-profile",
    "meta": {
      "profile": [
        "http://test.parity/StructureDefinition/observation-profile"
