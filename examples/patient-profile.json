{
  "resourceType": "StructureDefinition",
  "url": "http://example.org/fhir/StructureDefinition/patient-active-with-gender",
  "type": "Patient",
  "snapshot": {
    "element": [
      {
        "path": "Patient.identifier",
        "min": 1,
        "max": "*"
      },
      {
        "path": "Patient.active",
        "min": 1,
        "max": "1",
        "fixedBoolean": true,
        "constraint": [
          {
            "key": "active-required",
            "severity": "error",
            "expression": "active.exists()"
          }
        ]
      },
      {
        "path": "Patient.gender",
        "min": 1,
        "max": "1",
        "binding": {
          "strength": "required",
          "valueSet": "http://hl7.org/fhir/ValueSet/administrative-gender"
        }
      }
    ]
  }
}
