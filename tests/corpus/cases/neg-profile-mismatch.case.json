    },
    "gender": "male"
  },
  "structureDefinitions": [
    {
      "resourceType": "StructureDefinition",
      "url": "http://test.parity/StructureDefinition/observation-profile",
      "type": "Observation",
      "snapshot": {
        "element": [
          {
            "path": "Observation.status",
            "min": 1,
            "max": "1"
          }
        ]
      }
    }
  ],
  "config": {
    "profiles": {
      "Patient": [
        "http://test.parity/StructureDefinition/observation-profile"
      ]
    }
  },
  "oracle": {
    "status": "FAIL",
    "issues": [
      {
        "severity": "error",
        "code": "business-rule",
        "path": "Patient.meta.profile[0]"
      }
    ]
